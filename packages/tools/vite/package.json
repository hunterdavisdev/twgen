{
	"name": "@twgen/vite",
	"version": "0.1.0",
	"description": "Vite plugin for twgen — regenerates the Tailwind v4 theme CSS from your tokens on build and HMR",
	"license": "MIT",
	"author": "Hunter Davis",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hunterdavisdev/twgen.git",
		"directory": "packages/tools/vite"
	},
	"homepage": "https://github.com/hunterdavisdev/twgen#readme",
	"bugs": "https://github.com/hunterdavisdev/twgen/issues",
	"keywords": [
		"tailwind",
		"tailwindcss",
		"tailwind-v4",
		"vite-plugin",
		"design-tokens",
		"theme",
		"twgen"
	],
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"prepublishOnly": "bunx tsup"
	},
	"dependencies": {
		"@twgen/core": "workspace:*"
	},
	"peerDependencies": {
		"vite": ">=5"
	}
}
