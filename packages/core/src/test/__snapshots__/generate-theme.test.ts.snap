	--text-sm: 1;
	--text-sm--line-height: 1.5;
	--text-sm--font-weight: var(--th-text-sm-weight);

	/* Radius */
	--radius-md: 0.5rem;
}

@source inline("bg-{primary,secondary,text}");
@source inline("text-{sm}");
@source inline("rounded-{md}");
