{
	"name": "@twgen/core",
	"version": "0.1.0",
	"description": "Type-safe design tokens → Tailwind v4 @theme codegen (the twgen core: authoring API + generator)",
	"license": "MIT",
	"author": "Hunter Davis",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hunterdavisdev/twgen.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/hunterdavisdev/twgen#readme",
	"bugs": "https://github.com/hunterdavisdev/twgen/issues",
	"keywords": [
		"tailwind",
		"tailwindcss",
		"tailwind-v4",
		"design-tokens",
		"theme",
		"codegen",
		"css-variables"
	],
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"prepublishOnly": "tsup"
	},
	"dependencies": {
		"jiti": "^2.4.2"
	}
}
