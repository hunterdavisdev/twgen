{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["node", "bun"],
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"@twgen/core": ["./packages/core/src/index.ts"],
			"@twgen/core/node": ["./packages/core/src/node.ts"]
		}
	},
	"include": ["packages/*/src"]
}
