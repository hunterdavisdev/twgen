{
	"name": "twgen-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter @twgen/core build && bun run --filter @twgen/vite build && bun run --filter @twgen/react build && bun run --filter @twgen/cli build",
		"dev": "bun run --filter @twgen/core dev",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"check": "biome check --write .",
		"release": "bun scripts/release.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.12.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"happy-dom": "^20.10.6",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"tsup": "^8.5.0",
		"typescript": "~5.9.3",
		"vite": "^8.0.16"
	}
}
